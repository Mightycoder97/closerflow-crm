# Configuración del Backend de CloserFlow AI

# Base de datos (Reemplazar con la URL de tu base de datos de Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/closerflow

# Cola de Mensajes (Upstash Redis o local)
REDIS_URL=redis://localhost:6379

# Meta API Webhooks
META_VERIFY_TOKEN=mi_token_secreto_de_validacion_123
META_APP_SECRET=mi_app_secret_de_facebook
META_ACCESS_TOKEN=tu_meta_access_token_aqui
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui

# Inteligencia Artificial (DeepSeek Console API)
DEEPSEEK_API_KEY=tu_api_key_de_deepseek_aqui
DEEPSEEK_BASE_URL=https://api.deepseek.com
