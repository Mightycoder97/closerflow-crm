# =============================================
# CloserFlow CRM - Frontend Environment Variables
# =============================================
# Copy this file to .env and fill in the values.

# URL del Servidor FastAPI REST API
# Usado para todas las llamadas HTTP (chats, mensajes, envío de WhatsApp, análisis IA)
VITE_API_URL=http://localhost:8000/api/v1

# URL de WebSockets para recibir actualizaciones en tiempo real
# Usado para recibir mensajes entrantes de WhatsApp en tiempo real
VITE_WS_URL=ws://localhost:8000/ws
